# Міграції на Turso: Prisma Migrate не приймає libsql:// — застосуй SQL з каталогу prisma/migrations/
# через `turso db shell <імʼя-бд> < prisma/migrations/<назва>/migration.sql` або локально `prisma migrate dev` з file:./dev.db
DATABASE_URL=

# Токен Turso (обовʼязково для хмарної бази)
TURSO_AUTH_TOKEN=
